{
  "requirement_file": "03_password_reset.md",
  "expected_modules": {
    "重置流程": {
      "key_scenarios": [
        "已注册邮箱申请重置，收到重置邮件",
        "未注册邮箱申请重置，提示统一信息（防止邮箱枚举）"
      ]
    },
    "重置链接": {
      "key_scenarios": [
        "点击有效重置链接进入重置页面",
        "重置链接在 30 分钟后过期",
        "已使用的重置链接再次使用被拒绝",
        "生成新链接后旧链接失效"
      ]
    },
    "新密码规则": {
      "key_scenarios": [
        "新密码 7 位（低于 8 字符下限）被拒绝",
        "新密码仅含 2 种字符类型（不符合至少 3 种要求）被拒绝",
        "新密码与最近 3 次密码之一相同被拒绝",
        "新密码重置成功"
      ]
    },
    "安全要求": {
      "key_scenarios": [
        "重置成功后所有已登录设备自动登出（旧 token 失效）",
        "重置成功后发送邮件通知用户",
        "同一邮箱 1 小时内第 4 次申请重置触发限流",
        "同一 IP 1 小时内第 6 次申请重置触发限流"
      ]
    },
    "异常处理": {
      "key_scenarios": [
        "无效 token 统一返回'链接无效或已过期'"
      ]
    }
  },
  "expected_apis": [
    "POST /api/v1/password/forgot",
    "POST /api/v1/password/reset",
    "POST /api/v1/password/verify-token"
  ],
  "min_test_cases": 15,
  "must_cover_categories": ["正向", "反向", "边界"]
}
